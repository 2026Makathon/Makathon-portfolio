	public void dropNotes() {
		ArrayList<Beat> beatList = new ArrayList<Beat>();
		int startTime = 200;
		int gap = 125; // 기본 간격 (8비트)
		int totalDuration = 180000; // 3분

		// 난이도에 따른 간격 조정
		if (difficulty.equals("Hard")) {
			gap = 80; // 하드는 더 촘촘하게
		}

		// 7개의 키 배열
		String[] keys = { "S", "D", "F", "Space", "J", "K", "L" };

		// 모든 곡에 대해 노트를 생성하도록 조건 수정 (또는 특정 곡별로 설정 가능)
		if (titleName != null) {
			for (int i = 0; i * gap < totalDuration; i++) {
				int currentTime = startTime + (i * gap);

				// [구간 1: 0~40초] 순차적으로 한 개씩 (S -> D -> F -> ...)
				if (i * gap < 40000) {
					if (i % 4 == 0) {
						beatList.add(new Beat(currentTime, keys[i % 7]));
					}
				}
				// [구간 2: 40~100초] 박자가 빨라지며 무작위성 추가
				else if (i * gap < 100000) {
					if (i % 2 == 0) {
						beatList.add(new Beat(currentTime, keys[(i * 3) % 7]));
					}
					// 16박자마다 스페이스바 추가
					if (i % 16 == 0) {
						beatList.add(new Beat(currentTime, "Space"));
					}
				}
				// [구간 3: 100~150초] 하이라이트 (동시치기 발생)
				else if (i * gap < 150000) {
					beatList.add(new Beat(currentTime, keys[i % 3])); // 왼쪽(S,D,F) 중 하나
					beatList.add(new Beat(currentTime, keys[4 + (i % 3)])); // 오른쪽(J,K,L) 중 하나

					if (i % 8 == 0)
						beatList.add(new Beat(currentTime, "Space"));
				}
				// [구간 4: 150~180초] 마무리 정박
				else {
					if (i % 4 == 0) {
						beatList.add(new Beat(currentTime, (i % 8 == 0) ? "Space" : keys[i % 7]));
					}
				}
			}
		}

		// 리스트가 비었을 때를 대비한 안전장치
		if (beatList.isEmpty()) {
			beatList.add(new Beat(startTime, "Space"));
		}

		Beat[] beats = beatList.toArray(new Beat[beatList.size()]);
		int i = 0;
		gameMusic.start();

		while (i < beats.length && !isInterrupted()) {
			if (beats[i].getTime() <= gameMusic.getTime()) {
				Note note = new Note(beats[i].getNoteName());
				note.start();
				noteList.add(note);
				i++;
			}
			try {
				Thread.sleep(5);
			} catch (InterruptedException e) {
				return;
			}
		}
	}
