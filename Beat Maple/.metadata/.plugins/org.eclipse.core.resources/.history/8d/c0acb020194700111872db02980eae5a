package dynamic_beat_16;

import java.awt.Graphics2D;
import java.awt.Image;

import javax.swing.ImageIcon;

public class Note extends Thread {
	
	public static final int NOTE_WIDTH = 100;
    public static final int SPACE_WIDTH = 200;
    public static final int NOTE_HEIGHT = 30;

	private Image noteBasicImage = new ImageIcon(Main.class.getResource("/images/noteBasic.png")).getImage();
	private int x, y = 960 - (1400 / Main.SLEEP_TIME * Main.NOTE_SPEED) * Main.REACH_TIME;
	private String noteType;
	private boolean proceeded = true;
	
	public String getNoteType() {
		return noteType;
	}
	
	public boolean isProceeded() {
		return proceeded;
	}
	
	public void close() {
		proceeded = false;
	}
	
	public Note(String noteType) {
		if(noteType.equals("S")) {
			x = 528;
		}
		else if(noteType.equals("D")) {
			x = 632;
		}
		else if(noteType.equals("F")) {
			x = 736;
		}
		else if(noteType.equals("Space")) {
			x = 840;
		}
		else if(noteType.equals("J")) {
			x = 1044;
		}
		else if(noteType.equals("K")) {
			x = 1148;
		}
		else if(noteType.equals("L")) {
			x = 1252;
		}
		this.noteType = noteType;
	}
	
	public void screenDraw(Graphics2D g) {
		if(noteType.equals("Space"))
		{
			g.drawImage(noteBasicImage, x, y, SPACE_WIDTH, NOTE_HEIGHT, null);
		}
		else 
		{
			g.drawImage(noteBasicImage, x, y, NOTE_WIDTH, NOTE_HEIGHT, null);
		}
	}
	
	public void drop() {
		y += Main.NOTE_SPEED;
		if(y > 975) {
			System.out.println("Miss");
			close();
		}
	}
	
	
	@Override
	public void run() {
		try {
			while (true) {
				drop();
				if(proceeded) {
					Thread.sleep(Main.SLEEP_TIME);
					
				}
				else {
					interrupt();
					break;
				}
				Thread.sleep(Main.SLEEP_TIME);
			}
		} catch(Exception e) {
			System.err.println(e.getMessage());
		}
	}
	
	// Note.java

	// 판정 범위 상수를 정의합니다. (픽셀 단위, 판정선 기준 ±)
	// 이 값들을 조절하여 게임의 난이도를 밸런싱할 수 있습니다.
	public static final int PERFECT_RANGE = 20; // 최적: ±20px (매우 좁음)
	public static final int GREAT_RANGE = 40;   // ±40px
	public static final int GOOD_RANGE = 60;    // ±60px
	public static final int EARLY_LATE_RANGE = 80; // ±80px

	// 판정선 Y 좌표 (Game 클래스의 judgementLineImage 위치와 일치해야 함)
	public static final int JUDGEMENT_LINE_Y = 960; 

	public String judge() {
	    // 현재 노트의 중심점 Y 좌표를 계산합니다.
	    int noteCenterY = y + NOTE_HEIGHT / 2;
	    
	    // 판정선과의 거리를 구합니다.
	    int distance = Math.abs(noteCenterY - JUDGEMENT_LINE_Y);

	    // 판정 거리에 따라 결과를 반환하고 노트를 화면에서 지웁니다.
	    if (distance <= PERFECT_RANGE) {
	        setProceeded(false); // 노트 진행 중단 (화면에서 사라짐)
	        return "Perfect";
	    } else if (distance <= GREAT_RANGE) {
	        setProceeded(false);
	        return "Great";
	    } else if (distance <= GOOD_RANGE) {
	        setProceeded(false);
	        return "Good";
	    } else if (distance <= EARLY_LATE_RANGE) {
	        setProceeded(false);
	        // 거리가 판정선보다 위면 Early, 아래면 Late
	        return (noteCenterY < JUDGEMENT_LINE_Y) ? "Early" : "Late";
	    }

	    // 판정 범위 밖인 경우 None 반환 (아무 일도 일어나지 않음)
	    return "None";
	}
	
	
	
	
}
