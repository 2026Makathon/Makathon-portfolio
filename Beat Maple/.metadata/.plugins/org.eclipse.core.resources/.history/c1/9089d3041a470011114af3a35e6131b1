	// --- 노트 생성 및 낙하 로직 ---
	public void dropNotes() {
		Random rb = new Random(); 
		ArrayList<Beat> beatList = new ArrayList<Beat>();
		int startTime = 200;
		int gap = 125; 
		int totalDuration = 240000; // 4분

		// 난이도별 간격 설정
		if (difficulty.equals("Easy")) {
			gap = 175; 
		} else if (difficulty.equals("Hard")) {
			gap = 80;  
		}
		
		String[] keys = { "S", "D", "F", "Space", "J", "K", "L" };

		if (titleName != null) {
			for (int i = 0; i * gap < totalDuration; i++) {
				int currentTime = startTime + (i * gap);

				// [이지 난이도 로직]
				if (difficulty.equals("Easy")) {
					if (i % 4 == 0) {
						// 70% 확률로 랜덤 노트 생성
						if (rb.nextInt(10) < 7) { 
							String randomKey = keys[rb.nextInt(keys.length)];
							beatList.add(new Beat(currentTime, randomKey));
						}
					}
					continue; // 이지 난이도면 아래 구간 로직 건너뜀
				}
				
				// --- [노멀/하드 난이도 구간 로직] ---
				// 구간 1: 초반부 순차 생성
				if (i * gap < 40000) {
					if (i % 4 == 0) {
						beatList.add(new Beat(currentTime, keys[i % 7]));
					}
				}
				// 구간 2: 중반부 박자 변화 및 무작위성
				else if (i * gap < 100000) {
					if (i % 2 == 0) {
						beatList.add(new Beat(currentTime, keys[(i * 3) % 7]));
					}
					// 16박자마다 스페이스바
					if (i % 16 == 0) {
						beatList.add(new Beat(currentTime, "Space"));
					}
				}
				// 구간 3: 하이라이트 동시치기
				else if (i * gap < 150000) {
					beatList.add(new Beat(currentTime, keys[i % 3])); 
					beatList.add(new Beat(currentTime, keys[4 + (i % 3)])); 

					if (i % 8 == 0)
						beatList.add(new Beat(currentTime, "Space"));
				}
				// 구간 4: 마무리 정박
				else {
					if (i % 4 == 0) {
						beatList.add(new Beat(currentTime, (i % 8 == 0) ? "Space" : keys[i % 7]));
					}
				}
			}
		}

		// 리스트가 비었을 때 안전장치
		if (beatList.isEmpty()) {
			beatList.add(new Beat(startTime, "Space"));
		}

		Beat[] beats = beatList.toArray(new Beat[beatList.size()]);
		int i = 0;
		gameMusic.start();

		// 노트 드롭 스레드 루프
		while (i < beats.length && !isInterrupted()) {
			if (beats[i].getTime() <= gameMusic.getTime()) {
				Note note = new Note(beats[i].getNoteName());
				note.start();
				noteList.add(note);
				i++;
			}
			try {
				Thread.sleep(5);
			} catch (InterruptedException e) {
				return;
			}
		}
	}

	// --- 판정 로직 ---
	public void judge(String input) {
		for(int i = 0; i < noteList.size(); i++) {
			Note note = noteList.get(i);
			if(input.equals(note.getNoteType())){
				// [수정] note.judge()의 결과(Perfect, Great 등)를 judgeEvent에 전달
				judgeEvent(note.judge());
				break;
			}
		}
	}

	// --- [수정] 개편된 판정 이벤트 처리 로직 (중복 제거 및 정리) ---
	
	// 판정 및 플레어 이미지를 일정 시간 후 지우는 타이머 스레드 클래스 (내부 클래스)
	class ImageEffectTimer extends Thread {
		private String type;

		public ImageEffectTimer(String type) {
			this.type = type;
		}

		@Override
		public void run() {
			try {
				// 0.5초(500ms) 동안 이미지를 보여줍니다.
				Thread.sleep(500); 
				
				// 시간이 지나면 이미지를 null로 만들어 화면에서 지웁니다.
				if (type.equals("Flare")) {
					orangeFlareImage = null;
				} else if (type.equals("Judge")) {
					judgeImage = null;
				}
			} catch (InterruptedException e) {
				e.printStackTrace();
			}
		}
	}

	// 최종 판정 이벤트 처리 메서드
	public void judgeEvent(String judge) {
		// 판정 결과가 "None"이 아닐 때만 이펙트를 표시합니다.
		if (!judge.equals("None")) {
			// 1. 오렌지 플레어 이펙트 처리
			try {
				orangeFlareImage = new ImageIcon(Main.class.getResource("/images/orangeFlare.png")).getImage();
				// 기존에 실행 중인 타이머가 있어도 새로 시작하여 0.5초 후 null 처리
				new ImageEffectTimer("Flare").start(); 
			} catch (Exception e) {
				System.err.println("오렌지 플레어 이미지를 로드할 수 없습니다.");
				orangeFlareImage = null;
			}
			
			// 2. 판정 텍스트 이미지 처리 ("Miss"는 screenDraw에서 처리하므로 제외)
			if (!judge.equals("Miss")) {
				try {
					// 판정 결과(Perfect, Great 등)에 맞춘 파일명 생성
					String imagePath = "/images/judge" + judge + ".png"; 
					judgeImage = new ImageIcon(Main.class.getResource(imagePath)).getImage();
					// 0.5초 후 judgeImage를 null로 만드는 타이머 시작
					new ImageEffectTimer("Judge").start(); 
				} catch (Exception e) {
					System.err.println(judge + " 판정 이미지를 로드할 수 없습니다.");
					judgeImage = null; // 로드 실패 시 잔상 방지
				}
			}
		}
	}
