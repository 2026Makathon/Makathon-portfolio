	public void pressL() { judge("L"); keyPadLImage = new ImageIcon(Main.class.getResource("/images/keyPadPressed.png")).getImage(); }
	public void releaseL() { keyPadLImage = new ImageIcon(Main.class.getResource("/images/keyPadBasic.png")).getImage(); }

	@Override
	public void run() { dropNotes(); }
	public void close() { gameMusic.close(); this.interrupt(); }

	public void dropNotes() {
		// (기존 beatList 생성 로직 및 루프 작성)
		gameMusic.start();
	}
}