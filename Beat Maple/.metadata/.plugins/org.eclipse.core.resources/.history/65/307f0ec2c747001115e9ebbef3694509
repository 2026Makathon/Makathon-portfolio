package dynamic_beat_20;

import java.awt.Color;
import java.awt.Font;
import java.awt.Graphics2D;
import java.awt.Image;
import java.awt.RenderingHints;
import java.util.ArrayList;
import java.util.Random;
import javax.swing.ImageIcon;

import dynamic_beat_15.Main;
import dynamic_beat_15.Music;

public class Game extends Thread {

    // 이미지 변수 선언 (초기화는 생성자에서 안전하게 진행)
    private Image noteRouteSImage, noteRouteDImage, noteRouteFImage, noteRouteSpace1Image, 
                  noteRouteSpace2Image, noteRouteJImage, noteRouteKImage, noteRouteLImage;
    private Image noteRouteLineImage, judgementLineImage, gameInfoImage;
    private Image keyPadSImage, keyPadDImage, keyPadFImage, keyPadSpace1Image, 
                  keyPadSpace2Image, keyPadJImage, keyPadKImage, keyPadLImage;
    private Image resultImage;
    private Image orangeFlareImage = null;
    private Image judgeImage = null;

    private String titleName;
    private String difficulty;
    private String musicTitle;
    private Music gameMusic;

    ArrayList<Note> noteList = new ArrayList<Note>();

    private int score = 0;
    private int combo = 0;
    private int maxCombo = 0;
    private int comboFontSize = 40;
    private boolean showBonus = false;
    private int bonusTimer = 0;

    private int perfectCount = 0;
    private int goodCount = 0;
    private int missCount = 0;

    private boolean isGameResult = false;

    public Game(String titleName, String difficulty, String musicTitle) {
        this.titleName = titleName;
        this.difficulty = difficulty;
        this.musicTitle = musicTitle;
        
        // [안정화] 이미지 로딩을 생성자에서 수행하여 에러 발생 시 추적 용이하게 함
        try {
            noteRouteSImage = new ImageIcon(Main.class.getResource("/images/noteRoute.png")).getImage();
            noteRouteDImage = noteRouteSImage; // 중복 리소스는 재사용
            noteRouteFImage = noteRouteSImage;
            noteRouteSpace1Image = noteRouteSImage;
            noteRouteSpace2Image = noteRouteSImage;
            noteRouteJImage = noteRouteSImage;
            noteRouteKImage = noteRouteSImage;
            noteRouteLImage = noteRouteSImage;

            noteRouteLineImage = new ImageIcon(Main.class.getResource("/images/noteRouteLine.png")).getImage();
            judgementLineImage = new ImageIcon(Main.class.getResource("/images/judgementLine.png")).getImage();
            gameInfoImage = new ImageIcon(Main.class.getResource("/images/gameInfo.png")).getImage();

            ImageIcon basicKey = new ImageIcon(Main.class.getResource("/images/keyPadBasic.png"));
            keyPadSImage = basicKey.getImage();
            keyPadDImage = basicKey.getImage();
            keyPadFImage = basicKey.getImage();
            keyPadSpace1Image = basicKey.getImage();
            keyPadSpace2Image = basicKey.getImage();
            keyPadJImage = basicKey.getImage();
            keyPadKImage = basicKey.getImage();
            keyPadLImage = basicKey.getImage();

            // 결과 화면 배경 (가장 중요한 부분)
            java.net.URL resultURL = Main.class.getResource("/images/resultBackground.png");
            if(resultURL != null) {
                resultImage = new ImageIcon(resultURL).getImage();
            } else {
                // 파일이 없을 경우 검은색 배경으로 대체되도록 유도 (에러 방지)
                System.out.println("Warning: resultBackground.png not found.");
            }
        } catch (Exception e) {
            System.err.println("이미지 로딩 중 에러 발생: " + e.getMessage());
        }

        gameMusic = new Music(this.musicTitle, false);
    }

    public void screenDraw(Graphics2D g) {
        if (isGameResult) {
            drawResult(g);
            return;
        }

        // 기존 게임 화면 그리기 로직
        g.drawImage(noteRouteSImage, 528, 30, null);
        g.drawImage(noteRouteDImage, 632, 30, null);
        g.drawImage(noteRouteFImage, 736, 30, null);
        g.drawImage(noteRouteSpace1Image, 840, 30, null);
        g.drawImage(noteRouteSpace2Image, 940, 30, null);
        g.drawImage(noteRouteJImage, 1044, 30, null);
        g.drawImage(noteRouteKImage, 1148, 30, null);
        g.drawImage(noteRouteLImage, 1252, 30, null);

        g.drawImage(noteRouteLineImage, 524, 30, null);
        g.drawImage(noteRouteLineImage, 628, 30, null);
        g.drawImage(noteRouteLineImage, 732, 30, null);
        g.drawImage(noteRouteLineImage, 836, 30, null);
        g.drawImage(noteRouteLineImage, 1040, 30, null);
        g.drawImage(noteRouteLineImage, 1144, 30, null);
        g.drawImage(noteRouteLineImage, 1248, 30, null);
        g.drawImage(noteRouteLineImage, 1352, 30, null);

        g.drawImage(gameInfoImage, 0, 1020, null);
        g.drawImage(judgementLineImage, 0, 960, null);

        for (int i = 0; i < noteList.size(); i++) {
            Note note = noteList.get(i);
            if (!note.isProceeded()) {
                noteList.remove(i);
                i--;
            } else {
                if (note.getY() > 1040) {
                    judgeEvent("Miss");
                    note.setProceeded(false);
                }
                note.screenDraw(g);
            }
        }

        g.setColor(Color.white);
        g.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON);
        g.setFont(new Font("Arial", Font.BOLD, 30));
        g.drawString(titleName, 20, 1065);
        g.drawString(difficulty, 1820, 1060);

        g.setColor(Color.DARK_GRAY);
        g.drawString("S", 570, 1000);
        g.drawString("D", 672, 1000);
        g.drawString("F", 776, 1000);
        g.drawString("Space Bar", 870, 1000);
        g.drawString("J", 1084, 1000);
        g.drawString("K", 1188, 1000);
        g.drawString("L", 1295, 1000);

        g.setColor(Color.LIGHT_GRAY);
        g.setFont(new Font("Elephant", Font.BOLD, 30));
        g.drawString(String.format("%07d", score), 840, 1065);

        g.setColor(Color.WHITE);
        g.setFont(new Font("Arial", Font.BOLD, 25));
        g.drawString("MAX COMBO: " + maxCombo, 20, 50);

        if (combo > 0) {
            if (comboFontSize > 40) comboFontSize -= 2;
            g.setColor(Color.ORANGE);
            g.setFont(new Font("Elephant", Font.BOLD, comboFontSize));
            g.drawString("COMBO " + combo, 850 - (comboFontSize / 2), 200); 
        }

        if (showBonus) {
            g.setColor(Color.YELLOW);
            g.setFont(new Font("Arial", Font.BOLD, 40));
            g.drawString("50 COMBO BONUS! +1000", 650, 300);
            bonusTimer--;
            if (bonusTimer <= 0) showBonus = false;
        }

        if (orangeFlareImage != null) g.drawImage(orangeFlareImage, 320, 370, null);
        if (judgeImage != null) g.drawImage(judgeImage, 750, 650, null);

        g.drawImage(keyPadSImage, 528, 580, null);
        g.drawImage(keyPadDImage, 632, 580, null);
        g.drawImage(keyPadFImage, 736, 580, null);
        g.drawImage(keyPadSpace1Image, 840, 580, null);
        g.drawImage(keyPadSpace2Image, 940, 580, null);
        g.drawImage(keyPadJImage, 1044, 580, null);
        g.drawImage(keyPadKImage, 1148, 580, null);
        g.drawImage(keyPadLImage, 1252, 580, null);
    }

    // 결과 화면 전용 그리기 메서드 (가독성을 위해 분리)
    private void drawResult(Graphics2D g) {
        if(resultImage != null) g.drawImage(resultImage, 0, 0, null);
        else {
            g.setColor(Color.BLACK);
            g.fillRect(0, 0, 1920, 1080);
        }

        g.setColor(Color.WHITE);
        g.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON);
        g.setFont(new Font("Arial", Font.BOLD, 80));
        g.drawString("GAME OVER", 480, 200); 

        g.setFont(new Font("Arial", Font.BOLD, 40));
        g.drawString("Score: " + score, 500, 400);
        g.drawString("Max Combo: " + maxCombo, 500, 480);
        
        g.setColor(Color.CYAN);
        g.drawString("Perfect: " + perfectCount, 500, 560);
        g.setColor(Color.YELLOW);
        g.drawString("Good: " + goodCount, 500, 640);
        g.setColor(Color.RED);
        g.drawString("Miss: " + missCount, 500, 720);

        g.setFont(new Font("Elephant", Font.BOLD, 150));
        g.setColor(Color.ORANGE);
        String rank = (missCount == 0 && perfectCount > 0) ? "S" : (score > 10000 ? "A" : (score > 5000 ? "B" : "C"));
        g.drawString(rank, 900, 550);

        g.setFont(new Font("Arial", Font.PLAIN, 30));
        g.setColor(Color.LIGHT_GRAY);
        g.drawString("Press 'ESC' to go Back to Menu", 480, 900);
    }

    // ... (press/release 메서드들은 동일하므로 생략) ...

    @Override
    public void run() {
        dropNotes();
    }

    public void dropNotes() {
        // ... (노트 생성 로직 동일) ...
        // 예시용 비트 생성 코드 생략 (기존 코드 사용)

        Beat[] beats = beatList.toArray(new Beat[beatList.size()]);
        int i = 0;
        gameMusic.start();

        while (i < beats.length && !isInterrupted()) {
            if (beats[i].getTime() <= gameMusic.getTime()) {
                Note note = new Note(beats[i].getNoteName());
                note.start();
                noteList.add(note);
                i++;
            }
            try { Thread.sleep(5); } catch (InterruptedException e) { return; }
        }

        // [핵심] 모든 노트가 화면에서 사라질 때까지 대기
        try {
            Thread.sleep(3000); 
        } catch (InterruptedException e) { return; }

        if(!isInterrupted()) {
            isGameResult = true; 
            gameMusic.close();   
        }
    }

    public void judgeEvent(String judge) {
        if (!judge.equals("None")) {
            if (!judge.equals("Miss")) {
                combo++;
                if (combo > maxCombo) maxCombo = combo;
                if (judge.equals("Perfect")) { score += 100; perfectCount++; }
                else if (judge.equals("Good")) { score += 80; goodCount++; }
                comboFontSize = 65;
                if (combo > 0 && combo % 50 == 0) {
                    score += 1000;
                    showBonus = true;
                    bonusTimer = 30;
                }
                orangeFlareImage = new ImageIcon(Main.class.getResource("/images/orangeFlare.png")).getImage();
                new ImageEffectTimer("Flare").start();
            } else {
                combo = 0;
                missCount++;
            }

            try {
                judgeImage = new ImageIcon(Main.class.getResource("/images/judge" + judge + ".png")).getImage();
                new ImageEffectTimer("Judge").start();
            } catch (Exception e) { judgeImage = null; }
        }
    }

    // (나머지 내부 클래스 및 메서드 생략)
}